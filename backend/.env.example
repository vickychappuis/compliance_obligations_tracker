# Database
DATABASE_URL=postgresql+psycopg://compliance:compliance@localhost:5432/compliance
APP_ENV=development

# Supabase Storage (document files)
# Cloud project:  https://abcdefgh.supabase.co
# Local stack:    http://localhost:54321  (or http://host.docker.internal:54321 inside Docker)
SUPABASE_URL=
# Service-role key (server-side only - never expose to the browser, never commit)
# Cloud: Settings → API → service_role key
# Local: printed by `supabase start`, or run `supabase status`
SUPABASE_SERVICE_KEY=
# Create as a private bucket before first use:
#   cloud  → Storage tab in the Supabase dashboard
#   local  → supabase storage create-bucket obligation-documents --private
SUPABASE_BUCKET=obligation-documents
# Signed download URL lifetime, in seconds
SIGNED_URL_EXPIRY_SECONDS=3600
