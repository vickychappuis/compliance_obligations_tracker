# Database
DATABASE_URL=postgresql+psycopg://compliance:compliance@localhost:5432/compliance
APP_ENV=development

# Supabase Storage (document files)
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Service-role key (server-side only - never expose to the browser, never commit)
SUPABASE_SERVICE_KEY=
# Storage bucket name (create it as a private bucket in the Supabase dashboard)
SUPABASE_BUCKET=obligation-documents
# Signed download URL lifetime, in seconds
SIGNED_URL_EXPIRY_SECONDS=3600
